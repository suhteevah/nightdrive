# Rust build output
/target/
**/*.rs.bk
Cargo.lock.bak

# Secrets — NEVER commit
.env
.env.*
!.env.example

# Per-deployment runtime config (paths, URLs differ per host)
config/nightdrive.toml

# Pre-rendered SDXL cover library (regenerate via sidecar/generate_cover_library.py)
assets/covers/library/
# Per-album cover sets — regenerable via sidecar/generate_album_covers_native.py
# using the docs/albums/<slug>.json which IS in git. Large + deterministic.
assets/covers/albums/
# Per-album wallpaper sets — regenerable via the same script (writes the
# desktop + phone variants alongside the 1024² album cover).
assets/wallpapers/

# Claude Code scheduled-task state (regenerated by the harness)
.claude/scheduled_tasks.lock

# Python bytecode cache (sidecars)
**/__pycache__/
*.pyc

# Local state / runtime artifacts
/var/
/var/lib/nightdrive/
*.sqlite
*.sqlite-journal
*.sqlite-wal
*.sqlite-shm

# Editor / OS detritus
.idea/
.vscode/
*.swp
*.swo
.DS_Store
Thumbs.db

# Witness + audit ephemera (overwritten on each run)
target/witness-*.log
target/ollama-pull.log

# Added by uploader (secret-leak hardening, 2026-04-18)
.secrets
VOXCLAW.md
scratch/
*.local
nul
id_rsa
id_ed25519
*-key
.claude/.credentials.json
C:Users*
C:Windows*

# Windows reserved device names (cause git add failures)
nul
con
prn
aux
com1
com2
com3
com4
com5
com6
com7
com8
com9
lpt1
