# nightdrive .env — copy to .env and fill in. Do not commit .env.

# === Logging ===
RUST_LOG=nightdrive_orchestrator=debug,nightdrive_llm=debug,nightdrive_audio_gen=debug,nightdrive_youtube=info,sqlx=warn,hyper=warn
RUST_BACKTRACE=1

# === Paths ===
NIGHTDRIVE_CONFIG=/etc/nightdrive/nightdrive.toml
NIGHTDRIVE_WORK_DIR=/var/lib/nightdrive

# === YouTube OAuth (Data API v3) ===
# Generate these from Google Cloud Console: APIs & Services → Credentials → OAuth client (Desktop app)
# Then run: ./target/release/nightdrive-cli youtube auth   (one-time, opens browser)
NIGHTDRIVE_YT_CLIENT_ID=
NIGHTDRIVE_YT_CLIENT_SECRET=
NIGHTDRIVE_YT_REFRESH_TOKEN=

# === YouTube Live (RTMP) ===
# From YouTube Studio → Go Live → Stream → "Stream key" + the rtmp:// URL
NIGHTDRIVE_YT_STREAM_KEY=rtmp://a.rtmp.youtube.com/live2/REPLACE-ME

# === OpenClaw / Ollama (LLM for composition spec) ===
NIGHTDRIVE_OPENCLAW_URL=http://kokonoe.tailb85819.ts.net:11434
NIGHTDRIVE_OPENCLAW_MODEL=qwen2.5:7b-instruct

# === MusicGen wrapper (runs on supermicro) ===
NIGHTDRIVE_AUDIO_GEN_URL=http://supermicro.tailb85819.ts.net:8080
NIGHTDRIVE_AUDIO_GEN_MODEL=musicgen-large

# === SDXL cover art wrapper ===
NIGHTDRIVE_ART_URL=http://supermicro.tailb85819.ts.net:8081
NIGHTDRIVE_ART_MODEL=sdxl

# === OBS WebSocket (livestream control) ===
NIGHTDRIVE_OBS_WS_URL=wss://arch-controller.tailb85819.ts.net:4455
NIGHTDRIVE_OBS_WS_PASSWORD=
